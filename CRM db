CREATE TABLE `activities` (
	`id` INT(11) NOT NULL AUTO_INCREMENT,
	`title` VARCHAR(255) NULL DEFAULT NULL COLLATE 'utf8mb4_uca1400_ai_ci',
	`description` TEXT NULL DEFAULT NULL COLLATE 'utf8mb4_uca1400_ai_ci',
	`created_at` TIMESTAMP NULL DEFAULT current_timestamp(),
	PRIMARY KEY (`id`) USING BTREE
);

CREATE TABLE `clients` (
	`record_id` BIGINT(20) NOT NULL,
	`first_name` VARCHAR(100) NOT NULL COLLATE 'utf8mb4_uca1400_ai_ci',
	`last_name` VARCHAR(100) NOT NULL COLLATE 'utf8mb4_uca1400_ai_ci',
	`email` VARCHAR(255) NOT NULL COLLATE 'utf8mb4_uca1400_ai_ci',
	`phone` VARCHAR(30) NULL DEFAULT NULL COLLATE 'utf8mb4_uca1400_ai_ci',
	`contact_owner` VARCHAR(255) NULL DEFAULT NULL COLLATE 'utf8mb4_uca1400_ai_ci',
	`assoc_company` VARCHAR(255) NULL DEFAULT NULL COLLATE 'utf8mb4_uca1400_ai_ci',
	`lead_status` ENUM('New','In Progress','Connected','Open Deal','Open','Attempted to Contact') NULL DEFAULT 'New' COLLATE 'utf8mb4_uca1400_ai_ci',
	`created_at` TIMESTAMP NULL DEFAULT current_timestamp(),
	`legacy_id` VARCHAR(100) NULL DEFAULT NULL COLLATE 'utf8mb4_uca1400_ai_ci',
	PRIMARY KEY (`record_id`) USING BTREE,
	UNIQUE INDEX `email` (`email`) USING BTREE
);

CREATE TABLE `company` (
	`record_id` BIGINT(20) NOT NULL AUTO_INCREMENT,
	`company_name` VARCHAR(255) NOT NULL COLLATE 'utf8mb4_uca1400_ai_ci',
	`company_owner` VARCHAR(255) NULL DEFAULT NULL COLLATE 'utf8mb4_uca1400_ai_ci',
	`phone` VARCHAR(50) NULL DEFAULT NULL COLLATE 'utf8mb4_uca1400_ai_ci',
	`city` VARCHAR(255) NULL DEFAULT NULL COLLATE 'utf8mb4_uca1400_ai_ci',
	`country` VARCHAR(255) NULL DEFAULT NULL COLLATE 'utf8mb4_uca1400_ai_ci',
	`industry` VARCHAR(255) NOT NULL DEFAULT 'Other' COLLATE 'utf8mb4_uca1400_ai_ci',
	`created_at` TIMESTAMP NULL DEFAULT current_timestamp(),
	PRIMARY KEY (`record_id`) USING BTREE
);

CREATE TABLE `event_chats` (
	`id` INT(11) NOT NULL AUTO_INCREMENT,
	`event_id` INT(11) NOT NULL,
	`sender_name` VARCHAR(255) NOT NULL COLLATE 'utf8mb4_uca1400_ai_ci',
	`message_text` TEXT NOT NULL COLLATE 'utf8mb4_uca1400_ai_ci',
	`sent_at` TIMESTAMP NULL DEFAULT current_timestamp(),
	PRIMARY KEY (`id`) USING BTREE,
	INDEX `event_id` (`event_id`) USING BTREE,
	CONSTRAINT `event_chats_ibfk_1` FOREIGN KEY (`event_id`) REFERENCES `timetree_events` (`id`) ON UPDATE RESTRICT ON DELETE CASCADE
);

CREATE TABLE `otp_table` (
	`email` VARCHAR(255) NOT NULL COLLATE 'utf8mb4_uca1400_ai_ci',
	`otp` VARCHAR(10) NOT NULL COLLATE 'utf8mb4_uca1400_ai_ci',
	`expires_at` DATETIME NOT NULL,
	PRIMARY KEY (`email`) USING BTREE
);

CREATE TABLE `projects` (
	`id` INT(11) NOT NULL AUTO_INCREMENT,
	`deal_name` VARCHAR(255) NOT NULL COLLATE 'utf8mb4_uca1400_ai_ci',
	`status` ENUM('Lead','Proposal','Purchase Order','Site Survey-POC','Closed Lost','Completed Project','Inactive Project','Renewal Support','Previous Year Project','Recovered Project') NULL DEFAULT NULL COLLATE 'utf8mb4_uca1400_ai_ci',
	`paid_amount` DECIMAL(15,2) NULL DEFAULT '0.00',
	`due_amount` DECIMAL(15,2) NULL DEFAULT '0.00',
	`total_amount` DECIMAL(15,2) NULL DEFAULT '0.00',
	`deal_owner` VARCHAR(255) NULL DEFAULT NULL COLLATE 'utf8mb4_uca1400_ai_ci',
	`contact` VARCHAR(255) NULL DEFAULT NULL COLLATE 'utf8mb4_uca1400_ai_ci',
	`company` VARCHAR(255) NULL DEFAULT NULL COLLATE 'utf8mb4_uca1400_ai_ci',
	`description` TEXT NULL DEFAULT NULL COLLATE 'utf8mb4_uca1400_ai_ci',
	`closed_date` DATE NULL DEFAULT NULL,
	`created_at` TIMESTAMP NULL DEFAULT current_timestamp(),
	PRIMARY KEY (`id`) USING BTREE
);

CREATE TABLE `project_attachments` (
	`id` INT(11) NOT NULL AUTO_INCREMENT,
	`project_id` INT(11) NOT NULL,
	`file_name` VARCHAR(255) NOT NULL COLLATE 'utf8mb4_uca1400_ai_ci',
	`file_path` VARCHAR(255) NOT NULL COLLATE 'utf8mb4_uca1400_ai_ci',
	`uploaded_by` VARCHAR(100) NULL DEFAULT NULL COLLATE 'utf8mb4_uca1400_ai_ci',
	`created_at` TIMESTAMP NULL DEFAULT current_timestamp(),
	PRIMARY KEY (`id`) USING BTREE,
	INDEX `project_id` (`project_id`) USING BTREE,
	CONSTRAINT `1` FOREIGN KEY (`project_id`) REFERENCES `projects` (`id`) ON UPDATE RESTRICT ON DELETE CASCADE
);

CREATE TABLE `project_comments` (
	`id` INT(11) NOT NULL AUTO_INCREMENT,
	`project_id` INT(11) NOT NULL,
	`user_name` VARCHAR(255) NULL DEFAULT NULL COLLATE 'utf8mb4_uca1400_ai_ci',
	`comment_text` TEXT NULL DEFAULT NULL COLLATE 'utf8mb4_uca1400_ai_ci',
	`created_at` TIMESTAMP NULL DEFAULT current_timestamp(),
	PRIMARY KEY (`id`) USING BTREE,
	INDEX `project_id` (`project_id`) USING BTREE,
	CONSTRAINT `1` FOREIGN KEY (`project_id`) REFERENCES `projects` (`id`) ON UPDATE RESTRICT ON DELETE CASCADE
);

CREATE TABLE `tasks` (
	`id` INT(11) NOT NULL AUTO_INCREMENT,
	`user_id` INT(11) NULL DEFAULT NULL,
	`title` VARCHAR(255) NOT NULL COLLATE 'utf8mb4_uca1400_ai_ci',
	`priority` ENUM('High','Medium','Low') NULL DEFAULT 'Medium' COLLATE 'utf8mb4_uca1400_ai_ci',
	`status` ENUM('Pending','Completed') NULL DEFAULT 'Pending' COLLATE 'utf8mb4_uca1400_ai_ci',
	`deadline` DATE NULL DEFAULT NULL,
	`created_at` TIMESTAMP NULL DEFAULT current_timestamp(),
	`description` TEXT NULL DEFAULT NULL COLLATE 'utf8mb4_uca1400_ai_ci',
	PRIMARY KEY (`id`) USING BTREE,
	INDEX `user_id` (`user_id`) USING BTREE,
	CONSTRAINT `1` FOREIGN KEY (`user_id`) REFERENCES `users` (`id`) ON UPDATE RESTRICT ON DELETE CASCADE
);

CREATE TABLE `timetree_events` (
	`id` INT(11) NOT NULL AUTO_INCREMENT,
	`title` VARCHAR(255) NOT NULL COLLATE 'utf8mb4_uca1400_ai_ci',
	`event_date` DATE NOT NULL,
	`start_time` TIME NOT NULL,
	`created_at` TIMESTAMP NULL DEFAULT current_timestamp(),
	`deadline_date` DATE NULL DEFAULT NULL,
	`deadline_time` TIME NULL DEFAULT NULL,
	PRIMARY KEY (`id`) USING BTREE
);

CREATE TABLE `users` (
	`id` INT(11) NOT NULL AUTO_INCREMENT,
	`name` VARCHAR(255) NOT NULL COLLATE 'utf8mb4_uca1400_ai_ci',
	`email` VARCHAR(255) NOT NULL COLLATE 'utf8mb4_uca1400_ai_ci',
	`phone` VARCHAR(20) NOT NULL COLLATE 'utf8mb4_uca1400_ai_ci',
	`password` VARCHAR(255) NOT NULL COLLATE 'utf8mb4_uca1400_ai_ci',
	`role` ENUM('admin','manager','executive','finance','viewer') NOT NULL COLLATE 'utf8mb4_uca1400_ai_ci',
	`created_at` TIMESTAMP NULL DEFAULT current_timestamp(),
	`about` TEXT NULL DEFAULT NULL COLLATE 'utf8mb4_uca1400_ai_ci',
	`avatar` LONGTEXT NULL DEFAULT NULL COLLATE 'utf8mb4_uca1400_ai_ci',
	PRIMARY KEY (`id`) USING BTREE,
	UNIQUE INDEX `email` (`email`) USING BTREE
);
